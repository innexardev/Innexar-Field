# Innexar Field — copy to .env for local development
APP_ENV=development
PORT=8081
DATABASE_URL=postgres://fieldforge:fieldforge@localhost:5432/fieldforge?sslmode=disable
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-change-me-in-production-use-32-chars-min
JWT_EXPIRY_HOURS=24
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002,http://192.168.0.178:3000,http://192.168.0.178:3001,http://192.168.0.178:3002
NEXT_PUBLIC_API_URL=http://localhost:8081/api/v1
# Use LAN IP when testing from other devices; localhost when browsing on this machine only
NEXT_PUBLIC_APP_URL=http://192.168.0.178:3000
WEB_APP_URL=http://192.168.0.178:3000
ADMIN_PORT=3002

# Production URLs (field.innexar.app):
# NEXT_PUBLIC_APP_URL=https://app.field.innexar.app
# NEXT_PUBLIC_API_URL=https://api.field.innexar.app/api/v1
# NEXT_PUBLIC_MARKETING_URL=https://field.innexar.app
# Platform admin: https://admin.field.innexar.app

# Platform super_admin seed (set password in .env — never commit real secrets)
PLATFORM_ADMIN_EMAIL=admin@field.innexar.app
PLATFORM_ADMIN_PASSWORD=

# Stripe — optional in dev when debug.mock_stripe=true (admin UI can store encrypted copies in DB)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Encrypts platform_settings at rest (falls back to JWT_SECRET when unset)
# PLATFORM_SETTINGS_KEY=

# Cloudflare R2 — tenant logo uploads (onboarding + settings)
# When unset, dev falls back to local ./uploads served at /uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL (custom domain or https://pub-xxx.r2.dev)
R2_PUBLIC_URL=
# Set R2_MOCK=1 to store logos as data URLs (no R2 or disk needed)
R2_MOCK=
UPLOAD_LOCAL_DIR=uploads
UPLOAD_LOCAL_PUBLIC_URL=http://localhost:8081/uploads
