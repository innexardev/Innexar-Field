{
  "name": "@fieldforge/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 -H 0.0.0.0",
    "prebuild": "node scripts/generate-manifest.mjs",
    "build": "flock -w 600 .next-build.lock sh -c \"NODE_OPTIONS='--max-old-space-size=3072' next build --no-lint && node -e \\\"require('node:fs').accessSync('.next/BUILD_ID')\\\"\"",
    "start": "next start -p 3000 -H 0.0.0.0",
    "lint": "next lint",
    "test": "npx tsx --test lib/mobile/offline-queue.test.ts",
    "cap:sync": "cap sync",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "mobile:build": "next build && cap sync",
    "mobile:init": "cap add ios && cap add android && cap sync"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@fieldforge/config": "*",
    "@fieldforge/i18n": "*",
    "@fieldforge/platform": "*",
    "@fieldforge/sdk": "*",
    "@fieldforge/ui": "*",
    "next": "15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
